@inject IJSRuntime JS

@if (!_initialized)
{
    <div class="is-gate is-gate--loading"></div>
}
else if (_unlocked)
{
    @ChildContent
}
else
{
    <div class="is-gate">
        <form class="is-gate__card" @onsubmit="TryUnlock" @onsubmit:preventDefault="true">
            <h1 class="is-gate__title">InnerSky</h1>
            <p class="is-gate__subtitle">Enter the password to continue.</p>
            <input class="is-gate__input"
                   type="password"
                   placeholder="Password"
                   autofocus
                   @bind="_password"
                   @bind:event="oninput" />
            @if (_error)
            {
                <p class="is-gate__error" role="alert">Incorrect password. Try again.</p>
            }
            <button class="is-gate__button" type="submit">Enter</button>
        </form>
    </div>
}

@code {
    private const string Password = "cucumber asparagus";
    private const string StorageKey = "innersky.unlocked";

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private bool _initialized;
    private bool _unlocked;
    private bool _error;
    private string _password = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var stored = await JS.InvokeAsync<string?>("localStorage.getItem", StorageKey);
                _unlocked = stored == "true";
            }
            catch
            {
                _unlocked = false;
            }

            _initialized = true;
            StateHasChanged();
        }
    }

    private async Task TryUnlock()
    {
        if (_password == Password)
        {
            _unlocked = true;
            _error = false;
            await JS.InvokeVoidAsync("localStorage.setItem", StorageKey, "true");
        }
        else
        {
            _error = true;
            _password = string.Empty;
        }
    }
}
