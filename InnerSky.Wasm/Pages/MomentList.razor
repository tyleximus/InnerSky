@page "/moments"
@inject EmotionProfilesApiClient ApiClient

@using InnerSky.Wasm.Data
@using InnerSky.Wasm.Models
@using InnerSky.Wasm.Services
@using System.Globalization

<PageTitle>Moments</PageTitle>

<main class="container-fluid py-4 px-3 px-lg-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3 mb-4">
        <div>
            <p class="text-primary fw-semibold mb-1">InnerSky</p>
            <h1 class="display-6 fw-semibold mb-1">Moments</h1>
            <p class="text-secondary mb-0">Search, filter, edit, and organize saved emotion blends.</p>
        </div>
        <a class="btn btn-outline-primary" href="/">Create emotion blend</a>
    </div>

    <section class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-lg-4">
                    <label class="form-label fw-semibold" for="momentSearch">Search</label>
                    <input id="momentSearch" class="form-control" placeholder="Title, comment, blend, or emotion" @bind="SearchTerm" @bind:event="oninput" />
                </div>
                <div class="col-12 col-md-6 col-lg-2">
                    <label class="form-label fw-semibold" for="emotionFilter">Emotion</label>
                    <select id="emotionFilter" class="form-select" @bind="EmotionFilter">
                        <option value="">Any emotion</option>
                        @foreach (var emotion in PlutchikData.BaseEmotions)
                        {
                            <option value="@emotion.Id">@emotion.Label</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-md-6 col-lg-2">
                    <label class="form-label fw-semibold" for="fromDate">From</label>
                    <input id="fromDate" class="form-control" type="datetime-local" value="@FromLocalText" @onchange="OnFromChanged" />
                </div>
                <div class="col-12 col-md-6 col-lg-2">
                    <label class="form-label fw-semibold" for="toDate">To</label>
                    <input id="toDate" class="form-control" type="datetime-local" value="@ToLocalText" @onchange="OnToChanged" />
                </div>
                <div class="col-12 col-md-6 col-lg-2 d-flex gap-2">
                    <button class="btn btn-primary flex-fill" type="button" @onclick="ApplyFilters">Apply</button>
                    <button class="btn btn-outline-secondary" type="button" @onclick="ClearFilters">Clear</button>
                </div>
            </div>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">@ErrorMessage</div>
    }

    @if (IsLoading)
    {
        <div class="text-center text-secondary py-5">Loading moments...</div>
    }
    else if (Moments.Count == 0)
    {
        <section class="text-center bg-white border rounded-4 shadow-sm py-5 px-3">
            <h2 class="h4 fw-semibold">No moments found</h2>
            <p class="text-secondary mb-3">Try loosening the filters or create your first emotion blend.</p>
            <a class="btn btn-primary" href="/">Create emotion blend</a>
        </section>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <p class="text-secondary mb-0">Showing @Moments.Count of @TotalCount moments</p>
            <select class="form-select form-select-sm w-auto" value="@PageSize" @onchange="OnPageSizeChanged">
                <option value="12">12 per page</option>
                <option value="24">24 per page</option>
                <option value="48">48 per page</option>
            </select>
        </div>

        <section class="moments-grid">
            @foreach (var moment in Moments)
            {
                <article class="card border-0 shadow-sm h-100 moment-card" @onclick="() => OpenMoment(moment.Id)">
                    <div class="card-body d-flex flex-column gap-3">
                        <div>
                            <div class="text-secondary small mb-1">@moment.MomentUtc.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</div>
                            <h2 class="h5 fw-semibold mb-1">@moment.Title</h2>
                            @if (!string.IsNullOrWhiteSpace(moment.Comment))
                            {
                                <p class="text-secondary mb-0">@moment.Comment</p>
                            }
                        </div>
                        <div class="mt-auto d-flex flex-wrap gap-2">
                            @foreach (var blend in moment.Blends.Take(4))
                            {
                                <span class="badge rounded-pill text-bg-light border">@blend.Name</span>
                            }
                            @if (moment.Blends.Count > 4)
                            {
                                <span class="badge rounded-pill text-bg-secondary">+@(moment.Blends.Count - 4)</span>
                            }
                        </div>
                    </div>
                </article>
            }
        </section>

        <nav class="d-flex justify-content-center align-items-center gap-3 mt-4">
            <button class="btn btn-outline-primary" type="button" disabled="@(Page <= 1)" @onclick="PreviousPage">Previous</button>
            <span class="text-secondary">Page @Page of @Math.Max(TotalPages, 1)</span>
            <button class="btn btn-outline-primary" type="button" disabled="@(TotalPages == 0 || Page >= TotalPages)" @onclick="NextPage">Next</button>
        </nav>
    }
</main>

@if (SelectedMoment is not null)
{
    <div class="moment-drawer-layer">
        <div class="moment-drawer-backdrop" @onclick="CloseMoment"></div>
        <aside class="moment-drawer shadow-lg" role="dialog" aria-modal="true" aria-labelledby="momentDetailsTitle" @onclick:stopPropagation>
            <header class="d-flex justify-content-between align-items-start gap-3 mb-4">
                <div>
                    <p class="text-primary fw-semibold mb-1">Moment details</p>
                    <h2 id="momentDetailsTitle" class="h3 fw-semibold mb-0">@SelectedMoment.Title</h2>
                </div>
                <button class="btn-close" type="button" aria-label="Close" @onclick="CloseMoment"></button>
            </header>

            <section class="card border-0 bg-light mb-4">
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold" for="editTitle">Title <span class="text-danger">*</span></label>
                        <input id="editTitle" class="form-control" @bind="EditTitle" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold" for="editComment">Comment</label>
                        <textarea id="editComment" class="form-control" rows="4" @bind="EditComment"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold" for="editMomentDate">Date &amp; time <span class="text-danger">*</span></label>
                        <input id="editMomentDate" class="form-control" type="datetime-local" @bind="EditMomentLocal" />
                        <div class="form-text">Required and saved at minute precision.</div>
                    </div>
                    <button class="btn btn-primary" type="button" @onclick="SaveMoment" disabled="@IsSavingMoment">Save moment</button>
                </div>
            </section>

            <section>
                <div class="d-flex justify-content-between align-items-center gap-2 mb-3">
                    <h3 class="h5 fw-semibold mb-0">Emotion blends</h3>
                    <span class="text-secondary small">Drag rows to reorder</span>
                </div>

                <div class="d-flex flex-column gap-2">
                    @foreach (var blend in SelectedBlends)
                    {
                        <article class="moment-blend-row border rounded-4 p-3 bg-white @(DraggedBlendId == blend.Id ? "is-dragging" : null)"
                                 draggable="true"
                                 @ondragstart="() => StartDraggingBlend(blend.Id)"
                                 @ondragend="ClearDraggedBlend"
                                 @ondragenter:preventDefault
                                 @ondragover:preventDefault
                                 @ondrop:preventDefault
                                 @ondrop="() => DropBlend(blend.Id)">
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div>
                                    <strong><span class="moment-blend-row__handle" aria-hidden="true">☰</span> @blend.Name</strong>
                                    <div class="d-flex flex-wrap gap-2 mt-2">
                                        @foreach (var component in blend.Components)
                                        {
                                            <span class="badge rounded-pill text-bg-light border">@FormatEmotion(component)</span>
                                        }
                                    </div>
                                </div>
                                <button class="btn btn-sm btn-outline-danger" type="button" @onclick="() => RemoveBlend(blend.Id)">Remove</button>
                            </div>
                        </article>
                    }
                </div>
            </section>
        </aside>
    </div>
}

@code {
    private List<EmotionMomentApiResponse> Moments { get; set; } = [];
    private EmotionMomentApiResponse? SelectedMoment { get; set; }
    private List<EmotionProfileApiResponse> SelectedBlends { get; set; } = [];
    private string? ErrorMessage { get; set; }
    private bool IsLoading { get; set; } = true;
    private bool IsSavingMoment { get; set; }
    private int? DraggedBlendId { get; set; }

    private string? SearchTerm { get; set; }
    private string? EmotionFilter { get; set; }
    private DateTime? FromLocal { get; set; }
    private DateTime? ToLocal { get; set; }
    private int Page { get; set; } = 1;
    private int PageSize { get; set; } = 12;
    private int TotalCount { get; set; }
    private int TotalPages { get; set; }

    private string EditTitle { get; set; } = string.Empty;
    private string? EditComment { get; set; }
    private DateTime EditMomentLocal { get; set; }

    private string FromLocalText => FromLocal?.ToString("yyyy-MM-ddTHH:mm", CultureInfo.InvariantCulture) ?? string.Empty;
    private string ToLocalText => ToLocal?.ToString("yyyy-MM-ddTHH:mm", CultureInfo.InvariantCulture) ?? string.Empty;

    protected override async Task OnInitializedAsync() => await LoadMoments();

    private async Task LoadMoments()
    {
        IsLoading = true;
        ErrorMessage = null;

        try
        {
            var response = await ApiClient.ListMomentsAsync(new MomentsQuery(SearchTerm, string.IsNullOrWhiteSpace(EmotionFilter) ? null : EmotionFilter, FromLocal?.ToUniversalTime(), ToLocal?.ToUniversalTime(), Page, PageSize));
            Moments = response.Items.ToList();
            TotalCount = response.TotalCount;
            TotalPages = response.TotalPages;
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task ApplyFilters() { Page = 1; await LoadMoments(); }
    private async Task ClearFilters() { SearchTerm = null; EmotionFilter = null; FromLocal = null; ToLocal = null; Page = 1; await LoadMoments(); }
    private async Task PreviousPage() { if (Page <= 1) return; Page--; await LoadMoments(); }
    private async Task NextPage() { if (TotalPages == 0 || Page >= TotalPages) return; Page++; await LoadMoments(); }

    private async Task OnPageSizeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var pageSize))
        {
            PageSize = pageSize;
            Page = 1;
            await LoadMoments();
        }
    }

    private void OnFromChanged(ChangeEventArgs e) => FromLocal = ParseLocalDateTime(e.Value?.ToString());
    private void OnToChanged(ChangeEventArgs e) => ToLocal = ParseLocalDateTime(e.Value?.ToString());

    private static DateTime? ParseLocalDateTime(string? value) =>
        DateTime.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.AssumeLocal, out var parsed)
            ? new DateTime(parsed.Year, parsed.Month, parsed.Day, parsed.Hour, parsed.Minute, 0)
            : null;

    private async Task OpenMoment(int id)
    {
        ErrorMessage = null;
        try
        {
            SelectedMoment = await ApiClient.GetMomentAsync(id);
            if (SelectedMoment is null) return;

            SelectedBlends = SelectedMoment.Blends.OrderBy(b => b.SortOrder).ToList();
            EditTitle = SelectedMoment.Title;
            EditComment = SelectedMoment.Comment;
            var local = SelectedMoment.MomentUtc.ToLocalTime();
            EditMomentLocal = new DateTime(local.Year, local.Month, local.Day, local.Hour, local.Minute, 0);
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private void CloseMoment()
    {
        SelectedMoment = null;
        SelectedBlends = [];
        DraggedBlendId = null;
    }

    private async Task SaveMoment()
    {
        if (SelectedMoment is null || string.IsNullOrWhiteSpace(EditTitle))
        {
            ErrorMessage = "Title is required.";
            return;
        }

        IsSavingMoment = true;
        ErrorMessage = null;

        try
        {
            SelectedMoment = await ApiClient.UpdateMomentAsync(SelectedMoment.Id, new EmotionMomentUpdateApiRequest(EditTitle, EditComment, EditMomentLocal.ToUniversalTime()));
            await LoadMoments();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsSavingMoment = false;
        }
    }

    private void StartDraggingBlend(int blendId) => DraggedBlendId = blendId;

    private void ClearDraggedBlend() => DraggedBlendId = null;

    private async Task DropBlend(int targetBlendId)
    {
        if (SelectedMoment is null || DraggedBlendId is null || DraggedBlendId == targetBlendId) return;

        var sourceIndex = SelectedBlends.FindIndex(b => b.Id == DraggedBlendId.Value);
        var targetIndex = SelectedBlends.FindIndex(b => b.Id == targetBlendId);
        if (sourceIndex < 0 || targetIndex < 0) return;

        var moved = SelectedBlends[sourceIndex];
        SelectedBlends.RemoveAt(sourceIndex);
        SelectedBlends.Insert(targetIndex, moved);
        DraggedBlendId = null;

        try
        {
            await ApiClient.UpdateBlendOrderAsync(SelectedMoment.Id, SelectedBlends.Select(b => b.Id).ToList());
            await OpenMoment(SelectedMoment.Id);
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private async Task RemoveBlend(int blendId)
    {
        if (SelectedMoment is null) return;

        try
        {
            await ApiClient.RemoveBlendAsync(SelectedMoment.Id, blendId);
            await OpenMoment(SelectedMoment.Id);
            await LoadMoments();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private static string FormatEmotion(EmotionProfileApiComponentResponse component)
    {
        var level = (IntensityLevel)component.Level;
        var emotionLabel = PlutchikData.BaseEmotions.FirstOrDefault(e => e.Id == component.Emotion).Label ?? component.Emotion;
        var intensity = PlutchikData.LevelName(component.Emotion, level);
        return intensity.Equals(emotionLabel, StringComparison.OrdinalIgnoreCase) ? emotionLabel : $"{intensity} ({emotionLabel})";
    }
}
